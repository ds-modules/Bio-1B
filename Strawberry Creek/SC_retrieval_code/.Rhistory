source("~/Bio-1B/Strawberry Creek/SC_retrieval_code/Concatenate_StrawberryCreek_SP26.R")
# Write the final table
final_tbl <- site_tbl |>
left_join(site_level, by = "Site") |>
rename(
Fork = Site_Fork,
Restoration = `Major restoration since 2000?`
) |>
select(
Site,
Fork,
Restoration,
`Plant Biodiversity`,
`Canopy Cover`,
pH,
`Temp (C)`,
`Phosphate (ppm)`,
`Nitrate (ppm)`,
`Dissolved Oxygen (1mg/L)`,
`Coliform Bacteria CFUs/100mL`,
`E.coli bacteria (CFUs/100mL)`
)
# Save the final table to google drives
folder <- as_id("1MYpC3AyPB0dwFucEuUOUDXwIx_DpAKNX")
ss <- gs4_create(
"Pooled Student Data",
sheets = list(Sheet1 = final_tbl)
)
drive_mv(
ss,
path = folder,
name = "Pooled Student Data",
overwrite = TRUE
)
